# App
BACKEND_API_TOKEN=replace-with-secure-token  # ОБЯЗАТЕЛЬНО: сгенерировать через openssl rand -hex 32
REDIS_PASSWORD=replace-with-secure-redis-password  # ОБЯЗАТЕЛЬНО: сгенерировать через openssl rand -hex 32
REDIS_URL=redis://:YOUR_REDIS_PASSWORD@redis:6379  # Вставьте тот же пароль что в REDIS_PASSWORD выше
JOB_TTL_HOURS=24
NODE_ENV=production
PORT=3000
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=20
MAX_FILES_PER_REQUEST=10
MAX_CONCURRENT_JOBS=2  # Одновременных заданий; сверх лимита /upload → 429. С OCR держим 2 (RAM-лимит контейнера)
ALLOWED_EXTENSIONS=pdf,xlsx,docx,xls,jpg,jpeg,png
# Извлечение текста на сервере (backend/extract-text.js): PDF/JPG/PNG → OCR (tesseract),
# xls/xlsx/docx → python-хелпер. Структуру из текста извлекает агент (LLM).
# OCR_LANGS=rus+eng+bel   # языки OCR; пакеты tesseract-ocr-data-* должны быть в образе
# OCR_RLIMIT_AS_MB=640    # лимит адресного пространства для pdftotext/pdftoppm/tesseract (#57).
#   ВАЖНО: держите НИЖЕ лимита памяти контейнера (deploy: memory 768M), иначе cgroup-OOM
#   убьёт контейнер раньше, чем сработает per-process лимит. Требует prlimit (util-linux в образе).
# UI больше НЕ получает API-токен в браузер (#41/#105 P1). Страница закрыта HTTP Basic
# (PUBLIC_PAGE_BASIC_AUTH_* ниже); те же Basic-креды браузер сам шлёт на same-origin /upload,
# /job, /metrics/data (dual-auth в backend это принимает). BACKEND_API_TOKEN остаётся только
# серверным — для программных/MCP-вызовов. (Локальный dev: dev-proxy инжектит Bearer из
# BACKEND_API_TOKEN на стороне сервера — см. ui/nuxt.config.ts.)
# Rate limit для /upload: не больше RATE_LIMIT_MAX запросов за RATE_LIMIT_WINDOW_MS
# на один токен (0 = выключить). Защита от лавины agent-процессов (DoS).
RATE_LIMIT_MAX=20
RATE_LIMIT_WINDOW_MS=60000

# Метрики использования (/metrics, см. README). Дашборд закрыт тем же Basic, что и публичная
# страница (PUBLIC_PAGE_BASIC_AUTH_*); счётчики копятся в Redis без TTL. Параметры экономики:
# HOURLY_RATE_BYN — стоимость часа сотрудника для компании (оклад + налоги/соцстрах); 0 = скрыть экономику.
# MINUTES_PER_POSITION — ручное время на 1 позицию (клиент: 10 позиций ≈ 15–30 мин ⇒ ~2 мин).
#   Эти два — оценочные, уточнить с заказчиком.
# USD_BYN_RATE — ФОЛБЭК курса USD→BYN: живой курс запрашивается из НБРБ (api.nbrb.by, кэш 12 ч),
#   этот используется только при недоступности НБРБ.
HOURLY_RATE_BYN=18
MINUTES_PER_POSITION=2
USD_BYN_RATE=3.3

# Bitrix24
# Вебхук с правами CRM (crm.deal.add, crm.product.list, crm.company.list, crm.smart.invoice.list)
# + скоуп, под которым модуль shef.purchase публикует REST-контроллеры
# shef:purchase.api.procure* (имя скоупа подтвердить при создании вебхука в Б24).
NUXT_BITRIX24_WEBHOOK_URL=https://your-portal.bitrix24.ru/rest/1/replace-with-webhook-token/
B24_DEAL_CATEGORY_ID=1
B24_DEAL_DEFAULT_STAGE_ID=C1:NEW
# REST-контроллеры shef:purchase.api.procure* (компании, товары, договоры, сделки)
# вызываются через тот же вебхук NUXT_BITRIX24_WEBHOOK_URL выше — отдельного URL нет.

# Eval на реальных счетах БЕЗ риска для боевого портала (make eval-test, #93): вебхук
# ТЕСТОВОГО Bitrix24. Изолированный eval-стек (docker-compose.eval.yml) направляет создание
# сделок ТУДА — живой портал не трогается. Нужен ТОЛЬКО для make eval-test.
NUXT_BITRIX24_TEST_WEBHOOK_URL=https://your-TEST-portal.bitrix24.ru/rest/1/replace-with-TEST-webhook-token/

# AI — Claude Code Agent
CLAUDE_CODE_BIN=claude
AGENT_TIMEOUT_MS=300000  # Таймаут агента в мс (по умолчанию 5 минут)
# Ретрай агента на ТРАНЗИЕНТНЫЕ сбои провайдера (HTTP 429/5xx, сетевые, таймаут) с
# экспоненциальным бэкоффом+джиттером (#104). Перманентные ошибки (нет CLI, плохой ввод,
# не-JSON ответ) не ретраятся. 1 = ретрай выключен.
# ⚠️ У каждой попытки ПОЛНЫЙ AGENT_TIMEOUT_MS: худший случай ≈ AGENT_MAX_ATTEMPTS × таймаут
#    (по умолчанию 3 × 5 мин = 15 мин). При недоступности провайдера задание держит слот
#    всё это время; с MAX_CONCURRENT_JOBS=2 новые /upload в этот период получают 429.
#    Нужно «быстро падать» — снизьте AGENT_MAX_ATTEMPTS (или AGENT_TIMEOUT_MS).
AGENT_MAX_ATTEMPTS=3        # всего попыток (вкл. первую); 1 = выкл.
AGENT_RETRY_BASE_MS=1000    # базовая задержка бэкоффа, мс
AGENT_RETRY_MAX_MS=15000    # потолок задержки между попытками, мс
# Провайдер модели для агента в контейнере. Переменные проброшены через allowlist
# AGENT_ENV_KEYS (backend/agent-runner.js); подписочный `claude login` в контейнере НЕ работает.
#
# Вариант A — Anthropic (по умолчанию): задать ключ ниже. Без него первый /upload упадёт «Not logged in».
ANTHROPIC_API_KEY=replace-with-anthropic-api-key
# CLAUDE_MODEL=claude-sonnet-4-6   # опц.: конкретная модель (иначе — из настроек claude)
#
# Вариант B — DeepSeek (Anthropic-совместимый endpoint): ЗАКОММЕНТИРУЙ ANTHROPIC_API_KEY выше
# и задай переменные ниже (актуальные имена моделей сверь на platform.deepseek.com):
# ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
# ANTHROPIC_AUTH_TOKEN=replace-with-deepseek-key        # ключ DeepSeek; не коммитить
# ANTHROPIC_MODEL=deepseek-v4-pro[1m]                   # основная модель
# Маппинг «уровней» и сабагентов — ОБЯЗАТЕЛЬНО задать, иначе фоновые/субагентные вызовы уйдут
# на модель Anthropic, которой у DeepSeek нет (неконтролируемо / падения):
# ANTHROPIC_DEFAULT_OPUS_MODEL=deepseek-v4-pro[1m]
# ANTHROPIC_DEFAULT_SONNET_MODEL=deepseek-v4-pro[1m]
# ANTHROPIC_DEFAULT_HAIKU_MODEL=deepseek-v4-flash
# CLAUDE_CODE_SUBAGENT_MODEL=deepseek-v4-flash          # модель сабагентов (контролируем явно)
# CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1            # отключить телеметрию/автообновления
# CLAUDE_CODE_EFFORT_LEVEL=max                          # опционально: уровень «усилий»

# MCP
# Токен для защиты /mcp endpoint (ОБЯЗАТЕЛЬНО: openssl rand -hex 32)
NUXT_MCP_AUTH_TOKEN=replace-with-secure-token
# URL MCP сервера (внутри Docker-сети, не публикуется наружу).
# mcp-контейнер слушает порт 3000 внутри сети procure-net.
MCP_SERVER_URL=http://mcp:3000/mcp
# Каталог с загруженными файлами внутри mcp-контейнера (read-only том uploads).
# create_deal читает исходный файл по пути отсюда и кодирует в base64 для
# вложения в сделку. Менять только если переопределён маунт в compose.
NUXT_UPLOADS_DIR=/app/uploads
# Потолок размера вкладываемого файла (МБ) перед чтением в память + base64.
# Защита mcp-контейнера от исчерпания памяти. По умолчанию 25 (с запасом к
# MAX_FILE_SIZE_MB=20 на стороне app).
NUXT_MAX_ATTACH_MB=25

# Public page basic auth
# При PUBLIC_PAGE_ENABLED=true отданный UI закрыт HTTP Basic (middleware в backend/index.js):
# бандл UI отдаётся только после ввода логина/пароля; API-токен в браузер НЕ попадает (#41/#105 P1).
# Браузер сам шлёт эти Basic-креды на same-origin /upload, /job, /metrics/data (dual-auth в backend;
# Bearer там тоже принимается — для программных/MCP-вызовов, не из браузера).
# ⚠️ Basic ОБЯЗАТЕЛЕН для браузерного UI: если выключить публичную страницу или не задать пароль,
#    UI не сможет авторизоваться (токен ему не отдаётся) и запросы получат 401.
# Этим же Basic закрыт дашборд /metrics: без PUBLIC_PAGE_BASIC_AUTH_PASS он отдаёт 503.
PUBLIC_PAGE_ENABLED=true
# СМЕНИТЕ логин: дефолт «procure» предсказуем (#103). Используйте нетривиальное значение.
PUBLIC_PAGE_BASIC_AUTH_USER=procure
PUBLIC_PAGE_BASIC_AUTH_PASS=replace-with-secure-password  # ОБЯЗАТЕЛЬНО (иначе страница отдаёт 503)
PUBLIC_PAGE_RESPONSIBLE_USER_ID=20

# Reverse-proxy (общий nginx-proxy + acme-companion, внешняя сеть proxy-net)
# VIRTUAL_HOST / LETSENCRYPT_HOST — домен приложения (app слушает порт 3000,
# VIRTUAL_PORT задаётся в docker-compose.prod.yml).
VIRTUAL_HOST=purchase.example.com
LETSENCRYPT_HOST=purchase.example.com
# LETSENCRYPT_EMAIL используется глобально acme-companion (грабли #2),
# в per-app окружении app его дублировать не нужно.
LETSENCRYPT_EMAIL=admin@example.com

# Откат / закрепление версии образа (по умолчанию latest).
# Задайте конкретный sha-тег из GHCR, чтобы откатиться; Watchtower будет держать его
# (sha не двигается). Вернуть авто-обновление — закомментировать обратно.
# APP_IMAGE_TAG=sha-<commit>
# MCP_IMAGE_TAG=sha-<commit>
