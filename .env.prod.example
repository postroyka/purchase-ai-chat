# App
BACKEND_API_TOKEN=replace-with-secure-token  # ОБЯЗАТЕЛЬНО: сгенерировать через openssl rand -hex 32
REDIS_PASSWORD=replace-with-secure-redis-password  # ОБЯЗАТЕЛЬНО: сгенерировать через openssl rand -hex 32
REDIS_URL=redis://:YOUR_REDIS_PASSWORD@redis:6379  # Вставьте тот же пароль что в REDIS_PASSWORD выше
JOB_TTL_HOURS=24
NODE_ENV=production
PORT=3000
UPLOAD_DIR=uploads
UPLOADS_RETENTION_DAYS=7  # Авто-чистка: папки job'ов в uploads/ старше N суток удаляются (нижняя граница 1)
# Замеры времени на странице результата (#замеры): true → живой mm:ss при обработке + «⏱ всего … · агент …»
# по готовности (в лог на странице, НЕ в метрики). По умолчанию выключено.
SHOW_TIMINGS=false
# Пороги «быстро/медленно» по полному времени файла (оценочные — калибруйте, docs/PARSING_PERFORMANCE.md).
TIMING_FAST_MS=45000
TIMING_SLOW_MS=90000
# Скрыть блок «⏱ Диагностика скорости агента» в UI. По умолчанию (false) блок виден всегда, когда агент
# прислал perf-данные. ВНИМАНИЕ: только UI-косметика — perf-данные всё равно отдаются в JSON ответа
# /job/:id/status (result.feedback) и пишутся в лог `[perf-diag]`. Флаг прячет блок, но не данные из API.
HIDE_PERF_NOTE=false
# Диагностика канала «Обратная связь агента»: true → на каждом файле форсится тестовый отзыв агента
# (см. docs/FEEDBACK.md). На проде держать false — включать только для разовой проверки канала.
AGENT_FORCE_FEEDBACK=false
# NUXT_PUBLIC_GIT_SHA — версия билда в подвале UI (ТЗ §6). Задаётся НЕ здесь, а на СБОРКЕ образа:
#   Dockerfile.app (ARG GIT_SHA → ENV NUXT_PUBLIC_GIT_SHA), CI (deploy.yml) подставляет реальный commit sha.
#   Значение запекается в префрендеренную статику на `pnpm build` и в рантайме НЕ переопределяется —
#   в .env.prod не нужно, оставлено пометкой. 'dev' = локальная сборка без CI.
MAX_FILE_SIZE_MB=20
MAX_FILES_PER_REQUEST=10
MAX_CONCURRENT_JOBS=2  # Одновременных заданий; сверх лимита /upload → 429. С OCR держим 2 (RAM-лимит контейнера)
ALLOWED_EXTENSIONS=pdf,xlsx,docx,xls,jpg,jpeg,png
# Извлечение текста на сервере (backend/extract-text.js): PDF/JPG/PNG → OCR (tesseract),
# xls/xlsx/docx → python-хелпер. Структуру из текста извлекает агент (LLM).
# OCR_LANGS=rus+eng+bel   # языки OCR; пакеты tesseract-ocr-data-* должны быть в образе
# OCR_DPI=150             # DPI растеризации для скан-PDF (полностраничный OCR)
# MAX_OCR_PAGES=8         # макс. страниц для OCR скан-PDF (RAM/время при 1CPU/768M)
# #267: гибридный PDF (таблица — текст, шапка/печать с УНП — картинка). Если в текстовом слое нет
# УНП/ИНН, дополнительно OCR'им первые страницы плотнее, чтобы добыть реквизиты (метод pdftotext_ocr):
# OCR_FALLBACK_DPI=300    # DPI фолбэк-OCR (мелкий УНП в печати; выше DPI = лучше, но дороже по RAM)
# OCR_FALLBACK_PAGES=2    # сколько первых страниц OCR'ить в фолбэке (реквизиты обычно в шапке)
# OCR_RLIMIT_AS_MB=640    # лимит адресного пространства для pdftotext/pdftoppm/tesseract (#57).
#   ВАЖНО: держите НИЖЕ лимита памяти контейнера (deploy: memory 768M), иначе cgroup-OOM
#   убьёт контейнер раньше, чем сработает per-process лимит. Требует prlimit (util-linux в образе).
# UI больше НЕ получает API-токен в браузер (#41/#105 P1). Авторизация UI — через сессионную
# cookie приложения (HTTP Basic убран, он несовместим с iframe Bitrix24): standalone-вход через
# форму /login (логин/пароль = PUBLIC_PAGE_BASIC_AUTH_* ниже), внутри портала — молча через
# /session/b24 (валидация портала вызовом app.info). useApi добавляет заголовок X-PAI-Auth, и
# браузер шлёт cookie pai_sess на /upload, /job, /metrics/data. BACKEND_API_TOKEN остаётся только
# серверным — для программных/MCP-вызовов. (Локальный dev: dev-proxy инжектит Bearer из
# BACKEND_API_TOKEN на стороне сервера — см. ui/nuxt.config.ts.)
# Rate limit для /upload: не больше RATE_LIMIT_MAX запросов за RATE_LIMIT_WINDOW_MS
# на один токен (0 = выключить). Защита от лавины agent-процессов (DoS).
RATE_LIMIT_MAX=20
RATE_LIMIT_WINDOW_MS=60000

# Метрики использования (/metrics, см. README). Дашборд закрыт той же сессией приложения, что и
# остальной UI (вход — PUBLIC_PAGE_BASIC_AUTH_*); счётчики копятся в Redis без TTL. Параметры экономики:
# HOURLY_RATE_BYN — стоимость часа сотрудника для компании (оклад + налоги/соцстрах); 0 = скрыть экономику.
# MINUTES_PER_POSITION — ручное время на 1 позицию (клиент: 10 позиций ≈ 15–30 мин ⇒ ~2 мин).
#   Эти два — оценочные, уточнить с заказчиком.
# USD_BYN_RATE — ФОЛБЭК курса USD→BYN: живой курс запрашивается из НБРБ (api.nbrb.by, кэш 12 ч),
#   этот используется только при недоступности НБРБ.
HOURLY_RATE_BYN=18
MINUTES_PER_POSITION=2
USD_BYN_RATE=3.3

# Обратная связь (issue #182, см. docs/FEEDBACK.md). Один токен питает ДВА канала в этот репозиторий:
#   • «сотрудник» — на странице результата оценка (👍/👎/💡) + комментарий → GitHub issue;
#   • «агент» — ИИ-агент пишет «что мешает в инструментах/как улучшить» → GitHub issue (с дедупом).
# Без GITHUB_FEEDBACK_TOKEN оба канала ВЫКЛЮЧЕНЫ: виджет скрыт, POST /feedback → 503, agent-issue не
# заводятся (счётчики в /metrics пишутся всё равно). Токен: fine-grained PAT, ОДИН репо, Issues: Read and write.
# ⚠️ Бэкенд-контейнеру нужен исходящий HTTPS к api.github.com. При КРАТКОМ сбое issue не теряется:
#    он кладётся в durable-outbox (#190) и дослается фоном (POST /feedback → 202, не 502).
# ⚠️ Репозиторий по умолчанию приватный на запуске — поэтому в issue допустим контекст задания
#    (jobId/имя файла/№ сделки). Сделаете репо публичным — заведите ОТДЕЛЬНЫЙ приватный репо здесь.
# GITHUB_FEEDBACK_TOKEN=github_pat_xxx
GITHUB_FEEDBACK_REPO=postroyka/purchase-ai-chat
# Антиспам в наш репозиторий: не больше FEEDBACK_RATE_LIMIT_MAX отзывов с клиента за окно (считаются
# попытки, не успехи). Тот же Redis-лимитер, что у /upload.
FEEDBACK_RATE_LIMIT_MAX=5
# Durable-outbox (#190): как часто фоновый дренер пытается дослать отзывы, которые не ушли при кратком
# сбое GitHub. По умолчанию 60000 мс. Очередь живёт в Redis (если задан REDIS_URL), иначе в памяти.
# FEEDBACK_OUTBOX_INTERVAL_MS=60000

# Чат-бот Битрикс24 (docs/B24_BOT.md): НЕОБЯЗАТЕЛЬНЫЙ фолбэк application_token для валидации событий бота.
# Обычно токен захватывается АВТОМАТИЧЕСКИ: при установке (ONAPPINSTALL → POST /b24/app/event, #217) либо,
# если старый портал не шлёт ONAPPINSTALL на callback, — из ПЕРВОГО подлинного события бота (подлинность
# через app.info по домену из allowlist, #241). Этот env нужен лишь как явный фолбэк. НЕ вписывать сюда
# токен, перехваченный вручную из трафика, — это не штатный путь.
B24_BOT_APPLICATION_TOKEN=
# Дебаг чат-бота (#241, портал-QA): логировать форму события — только MESSAGE/FILES + bot{id,endpoint,
# hasToken} (без токенов) — чтобы сверить форму FILES старого портала. По умолчанию ВКЛ; выкл — =false.
# B24_BOT_DEBUG=false
FEEDBACK_RATE_LIMIT_WINDOW_MS=3600000

# Bitrix24
# Вебхук с правами CRM (crm.deal.add, crm.product.list, crm.company.list, crm.smart.invoice.list)
# + скоуп, под которым модуль shef.purchase публикует REST-контроллеры
# shef:purchase.api.procure* (имя скоупа подтвердить при создании вебхука в Б24).
NUXT_BITRIX24_WEBHOOK_URL=https://your-portal.bitrix24.ru/rest/1/replace-with-webhook-token/
B24_DEAL_CATEGORY_ID=1
B24_DEAL_DEFAULT_STAGE_ID=C1:NEW
# Кто вправе встраивать приложение во фрейм (CSP frame-ancestors). По умолчанию — облачные
# домены Bitrix24 (*.bitrix24.ru/.com/.by). Для self-hosted КОРОБКИ укажите origin вашего
# портала (через пробел можно несколько), иначе приложение не откроется во фрейме портала.
# ⚠️ Эта же переменная задаёт allowlist доменов для серверной валидации /session/b24 (вызов
#    app.info при входе из фрейма): backend доверяет ровно тем доменам, которым разрешено
#    встраивать приложение. Для КОРОБКИ обязательно укажите здесь origin портала — иначе вход
#    внутри Bitrix24 не пройдёт (домен не в allowlist → 400).
# B24_FRAME_ANCESTORS=https://portal.example.com
# REST-контроллеры shef:purchase.api.procure* (компании, товары, договоры, сделки)
# вызываются через тот же вебхук NUXT_BITRIX24_WEBHOOK_URL выше — отдельного URL нет.

# Eval на реальных счетах БЕЗ риска для боевого портала (make eval-test, #93): вебхук
# ТЕСТОВОГО Bitrix24. Изолированный eval-стек (docker-compose.eval.yml) направляет создание
# сделок ТУДА — живой портал не трогается. Нужен ТОЛЬКО для make eval-test.
NUXT_BITRIX24_TEST_WEBHOOK_URL=https://your-TEST-portal.bitrix24.ru/rest/1/replace-with-TEST-webhook-token/

# AI — Claude Code Agent
CLAUDE_CODE_BIN=claude
AGENT_TIMEOUT_MS=360000  # Лимит ОДНОЙ попытки claude в мс (по умолчанию 6 минут, #260)
# #285: AGENT_FILE_BUDGET_MS — ОБЩИЙ wall-clock бюджет на обработку одного файла: извлечение
# текста/OCR + ВСЕ попытки + grace. Раньше «6 мин» ограничивали лишь одну попытку, поэтому скан с
# тяжёлым OCR + ретраи мог занять ~7 мин. Бюджет — потолок файла целиком: исчерпан → стоп с timeout.
# По умолчанию = 2× AGENT_TIMEOUT_MS (12 мин): сохраняет прежний худший случай (одна полная попытка
# ПОСЛЕ долгого OCR) + запас на один транзиентный ретрай, не регрессируя тяжёлые сканы. Не меньше
# одной попытки. Реальный wall-clock может превысить бюджет на ≤ grace (SIGTERM→SIGKILL).
AGENT_FILE_BUDGET_MS=720000  # общий бюджет на файл (extract+все попытки), мс; default = 2× AGENT_TIMEOUT_MS
# #44 (P1): окно graceful-shutdown — сколько ждать завершения ТЕКУЩИХ заданий при SIGTERM (деплой/
# рестарт) перед выходом, мс. Ставь ≈ AGENT_FILE_BUDGET_MS, чтобы при обновлении не убить разбор на
# полпути. ⚠️ `stop_grace_period` сервиса app и Watchtower `--stop-timeout` в docker-compose.prod.yml
# ДОЛЖНЫ быть БОЛЬШЕ этого окна (запас ~30 с) — иначе Docker/Watchtower пришлёт SIGKILL раньше.
# Что не успело — поднимет recovery при следующем старте (статус error, без «зомби»). Default 25000.
SHUTDOWN_DRAIN_MS=720000     # окно ожидания текущих заданий при рестарте, мс (≈ AGENT_FILE_BUDGET_MS)
# Ретрай агента на ТРАНЗИЕНТНЫЕ сбои провайдера (HTTP 429/5xx, сетевые) с экспоненциальным
# бэкоффом+джиттером (#104). Перманентные ошибки (нет CLI, плохой ввод, не-JSON ответ) И наши
# таймауты (попытки #260 и бюджета файла #285) НЕ ретраятся. 1 = ретрай выключен.
# ⚠️ Транзиентные сбои занимают слот до AGENT_MAX_ATTEMPTS попыток, НО суммарно не дольше
#    AGENT_FILE_BUDGET_MS; с MAX_CONCURRENT_JOBS=2 новые /upload в этот период получают 429.
AGENT_MAX_ATTEMPTS=3        # всего попыток (вкл. первую); 1 = выкл.
AGENT_RETRY_BASE_MS=1000    # базовая задержка бэкоффа, мс
AGENT_RETRY_MAX_MS=15000    # потолок задержки между попытками, мс
# Allowlist инструментов агента (#105 P2, принцип наименьших привилегий): агенту доступны ТОЛЬКО
# Read + наши MCP-инструменты b24_pst_crm_* (сервер mcp__procure-ai__). Так новые встроенные
# инструменты будущих версий CLI не окажутся доступны агенту, работающему с НЕДОВЕРЕННЫМ файлом.
# По умолчанию задавать НЕ нужно. Переопредели, ТОЛЬКО если в окружении другое имя MCP-сервера:
# AGENT_ALLOWED_TOOLS=Read,mcp__procure-ai__b24_pst_crm_find_supplier,mcp__procure-ai__b24_pst_crm_find_contract,mcp__procure-ai__b24_pst_crm_find_product,mcp__procure-ai__b24_pst_crm_find_products,mcp__procure-ai__b24_pst_crm_create_deal
# Провайдер модели для агента в контейнере. Переменные проброшены через allowlist
# AGENT_ENV_KEYS (backend/agent-runner.js); подписочный `claude login` в контейнере НЕ работает.
#
# Вариант A — Anthropic (по умолчанию): задать ключ ниже. Без него первый /upload упадёт «Not logged in».
ANTHROPIC_API_KEY=replace-with-anthropic-api-key
# CLAUDE_MODEL=claude-sonnet-4-6   # опц.: конкретная модель (иначе — из настроек claude)
#
# Вариант B — DeepSeek (Anthropic-совместимый endpoint): ЗАКОММЕНТИРУЙ ANTHROPIC_API_KEY выше
# и задай переменные ниже (актуальные имена моделей сверь на platform.deepseek.com):
# ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
# ANTHROPIC_AUTH_TOKEN=replace-with-deepseek-key        # ключ DeepSeek; не коммитить
# ANTHROPIC_MODEL=deepseek-v4-pro[1m]                   # основная модель
# Маппинг «уровней» и сабагентов — ОБЯЗАТЕЛЬНО задать, иначе фоновые/субагентные вызовы уйдут
# на модель Anthropic, которой у DeepSeek нет (неконтролируемо / падения):
# ANTHROPIC_DEFAULT_OPUS_MODEL=deepseek-v4-pro[1m]
# ANTHROPIC_DEFAULT_SONNET_MODEL=deepseek-v4-pro[1m]    # tier sonnet (основной агент — если НЕ задан ANTHROPIC_MODEL/CLAUDE_MODEL выше)
# ANTHROPIC_DEFAULT_HAIKU_MODEL=deepseek-v4-flash
# CLAUDE_CODE_SUBAGENT_MODEL=deepseek-v4-flash          # модель сабагентов (контролируем явно)
# CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1            # отключить телеметрию/автообновления
# CLAUDE_CODE_EFFORT_LEVEL=max                          # уровень «усилий»/размышления (Claude Code/Anthropic).
#   ℹ️ СКОРОСТЬ (#279): «думание» модели — узкое место (замер: агент ~91–115 с из ~96–115 с файла,
#   REST лишь 4.4 с). НО A/B `max` vs `medium` на одном счёте — БЕЗ разницы по скорости: DeepSeek через
#   Anthropic-совместимый endpoint этот параметр ИГНОРИРУЕТ. Рычаг неработоспособен на DeepSeek.
#   Единственный реальный рычаг — СМЕНА МОДЕЛИ: убрать `[1m]` (контекст 1 млн избыточен для ~20k-токенного
#   счёта) → `deepseek-v4-pro` (низкий риск, A/B); либо `deepseek-v4-flash` для основного агента (быстрее,
#   но проверить точность матчинга). Где смотреть время: «Лог обработки» (`SHOW_TIMINGS=true`) —
#   `агент … (из них инструменты …)`. Применение в прод — ops/owner-решение. Детали — docs/PARSING_PERFORMANCE.md.

# MCP
# Токен для защиты /mcp endpoint (ОБЯЗАТЕЛЬНО: openssl rand -hex 32).
# МИНИМУМ 32 символа (#105 P3): более короткий токен трактуется как «не настроен» → /mcp отдаёт 503
# (защита от опечатки/обрезанного значения). `openssl rand -hex 32` даёт 64 символа.
NUXT_MCP_AUTH_TOKEN=replace-with-secure-token
# ⚠️ НЕ задавайте NUXT_BITRIX24_OAUTH_ENABLED — он есть в upstream `mcp/.env.example`,
# но у нас webhook-only: OAuth/DXT-мультитенант выключен и закреплён в Dockerfile.mcp.
# Включение без тома под SQLite token-store → токены теряются при рестарте (см. mcp/VENDOR.md).
# URL MCP сервера (внутри Docker-сети, не публикуется наружу).
# mcp-контейнер слушает порт 3000 внутри сети procure-net.
MCP_SERVER_URL=http://mcp:3000/mcp
# Каталог с загруженными файлами внутри mcp-контейнера (read-only том uploads).
# create_deal читает исходный файл по пути отсюда и кодирует в base64 для
# вложения в сделку. Менять только если переопределён маунт в compose.
NUXT_UPLOADS_DIR=/app/uploads
# Потолок размера вкладываемого файла (МБ) перед чтением в память + base64.
# Защита mcp-контейнера от исчерпания памяти. По умолчанию 25 (с запасом к
# MAX_FILE_SIZE_MB=20 на стороне app).
NUXT_MAX_ATTACH_MB=25

# App auth (login-форма + сессия)
# HTTP Basic убран (несовместим с iframe Bitrix24). Сам UI теперь отдаётся ОТКРЫТО, чтобы фрейм
# портала мог его загрузить; доступ к API закрыт сессией приложения (подписанная cookie pai_sess):
#  • вне Bitrix24 (напрямую в браузере) — встроенная форма входа /login по логину/паролю ниже;
#  • внутри портала — сессия ставится молча через /session/b24 (backend проверяет портал вызовом
#    app.info; allowlist доменов берётся из B24_FRAME_ANCESTORS — для коробки задайте его выше);
#  • GET /session — внутренний probe-эндпоинт UI: возвращает { authenticated: true/false } без
#    параметров, используется при bootstrap standalone-режима для определения, нужна ли форма входа.
# API-токен в браузер НЕ попадает (#41/#105 P1); useApi шлёт заголовок X-PAI-Auth + cookie на
# /upload, /job, /metrics/data. Bearer (BACKEND_API_TOKEN) принимается для программных/MCP-вызовов.
# ⚠️ Пароль ОБЯЗАТЕЛЕН: без PUBLIC_PAGE_BASIC_AUTH_PASS форма /login отдаёт 503, а доступ к API
#    остаётся только по Bearer (браузерный UI авторизоваться не сможет). Этим же доступом закрыт
#    дашборд /metrics.
# СМЕНИТЕ логин: дефолт «procure» предсказуем (#103). Используйте нетривиальное значение.
PUBLIC_PAGE_BASIC_AUTH_USER=procure
PUBLIC_PAGE_BASIC_AUTH_PASS=replace-with-secure-password  # ОБЯЗАТЕЛЬНО (иначе /login отдаёт 503)
PUBLIC_PAGE_RESPONSIBLE_USER_ID=20
# Секрет для подписи сессионной cookie (pai_sess). Если не задан — выводится детерминированно из
# PUBLIC_PAGE_BASIC_AUTH_PASS (если задан), иначе из BACKEND_API_TOKEN. Стабилен между рестартами
# одного инстанса, но: смена пароля (или токена, если пароль не задан) инвалидирует все активные
# сессии. При нескольких инстансах за балансировщиком ЗАДАЙТЕ ЯВНО один и тот же секрет на всех
# (иначе cookie, выданная одним инстансом, не пройдёт проверку на другом). В проде рекомендуется
# задавать явно — это защищает от непреднамеренной инвалидации при ротации учётных данных.
# openssl rand -hex 32
# SESSION_SECRET=replace-with-secure-session-secret
# Время жизни сессии в часах (по умолчанию 12).
# SESSION_TTL_HOURS=12
# Число доверенных прокси-хопов (по умолчанию 1). Нужно, чтобы per-IP лимиты /login и /session/b24
# видели реальный IP клиента, а не IP nginx-proxy. За стандартным nginx-proxy дефолт (1) корректен.
# При нестандартной топологии (CDN, несколько прокси) задайте число хопов, 'loopback' или список IP/CIDR.
# TRUST_PROXY=1

# Reverse-proxy (общий nginx-proxy + acme-companion, внешняя сеть proxy-net)
# VIRTUAL_HOST / LETSENCRYPT_HOST — домен приложения (app слушает порт 3000,
# VIRTUAL_PORT задаётся в docker-compose.prod.yml).
VIRTUAL_HOST=purchase.example.com
LETSENCRYPT_HOST=purchase.example.com
# LETSENCRYPT_EMAIL используется глобально acme-companion (грабли #2),
# в per-app окружении app его дублировать не нужно.
LETSENCRYPT_EMAIL=admin@example.com

# Откат / закрепление версии образа (по умолчанию latest).
# Задайте конкретный sha-тег из GHCR, чтобы откатиться; Watchtower будет держать его
# (sha не двигается). Вернуть авто-обновление — закомментировать обратно.
# APP_IMAGE_TAG=sha-<commit>
# MCP_IMAGE_TAG=sha-<commit>
