# App
BACKEND_API_TOKEN=replace-with-secure-token
REDIS_URL=redis://redis:6379
JOB_TTL_HOURS=24
NODE_ENV=production
PORT=3000
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=20
ALLOWED_EXTENSIONS=pdf,xlsx,docx

# Bitrix24
B24_WEBHOOK_URL=https://your-portal.bitrix24.ru/rest/1/xxxxx/
B24_CONTRACTS_API_URL=https://your-portal.bitrix24.ru/rest/your_controller/
B24_DEAL_CATEGORY_ID=1
B24_DEAL_DEFAULT_STAGE_ID=C1:NEW

# AI
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
CLAUDE_CODE_BIN=claude

# MCP
MCP_SERVER_URL=http://mcp:3001/sse

# Public page
PUBLIC_PAGE_ENABLED=true
PUBLIC_PAGE_BASIC_AUTH_USER=someDeal
PUBLIC_PAGE_BASIC_AUTH_PASS=
PUBLIC_PAGE_RESPONSIBLE_USER_ID=20

# Nginx proxy
VIRTUAL_HOST=purchase.postroyka.by
LETSENCRYPT_HOST=purchase.postroyka.by
LETSENCRYPT_EMAIL=admin@postroyka.by
