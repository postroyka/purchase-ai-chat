# Backend local dev environment
# Скопировать: cp .env.example .env
# .env не коммитится (в .gitignore)

BACKEND_API_TOKEN=dev-token-local
NODE_ENV=development
PORT=3000
UPLOAD_DIR=uploads
# Авто-чистка uploads/: удалять папки job'ов старше N суток (нижняя граница — 1). По умолчанию 7.
UPLOADS_RETENTION_DAYS=7
MAX_FILE_SIZE_MB=20
MAX_FILES_PER_REQUEST=10
ALLOWED_EXTENSIONS=pdf,xlsx,docx,xls,jpg,jpeg,png
# OCR_LANGS=rus+eng+bel   # языки OCR (нужен tesseract на хосте); OCR_DPI=150, MAX_OCR_PAGES=8 — тюнинг

# Замеры времени на странице результата (#замеры): при true /job/:id/status отдаёт тайминги по файлам,
# UI показывает живой mm:ss во время обработки и «⏱ всего … · агент …» по готовности. Только в лог на
# странице, НЕ в метрики. По умолчанию выключено (opt-in).
SHOW_TIMINGS=false

# Redis — оставить пустым для in-memory (нормально для Week 1 локально)
# Или: redis://localhost:6379
REDIS_URL=
JOB_TTL_HOURS=24

# Claude Code Agent (backend/agent-runner.js → runAgent)
CLAUDE_CODE_BIN=claude
AGENT_TIMEOUT_MS=300000           # таймаут агента в мс (5 мин)
# Ретрай на транзиентные сбои провайдера (429/5xx/сеть/таймаут) с бэкоффом+джиттером (#104).
# Перманентные ошибки не ретраятся. Каждая попытка — полный AGENT_TIMEOUT_MS. 1 = выкл.
AGENT_MAX_ATTEMPTS=3              # всего попыток (вкл. первую)
AGENT_RETRY_BASE_MS=1000         # базовая задержка бэкоффа, мс
AGENT_RETRY_MAX_MS=15000         # потолок задержки между попытками, мс
# CLAUDE_MODEL=claude-sonnet-4-6  # опционально: модель агента (по умолч. — из настроек claude CLI)
# ANTHROPIC_API_KEY=sk-ant-...    # нужен ТОЛЬКО если не залогинен интерактивно (claude login).
                                  # В Docker подписочная сессия не работает — ключ обязателен.
# DeepSeek вместо Anthropic: вместо ANTHROPIC_API_KEY задать
# ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic + ANTHROPIC_AUTH_TOKEN + ANTHROPIC_MODEL.

# MCP — для локального e2e подними mcp отдельно. Backend уже занимает :3000, поэтому
# запускай MCP на ДРУГОМ порту и укажи его здесь. Оставь пустым, если агент не нужен.
MCP_SERVER_URL=http://localhost:3002/mcp
NUXT_MCP_AUTH_TOKEN=
