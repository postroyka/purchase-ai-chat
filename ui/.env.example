# --- APP SETTINGS ---
# The public URL of the application (e.g., https://example.com)
NUXT_PUBLIC_SITE_URL=

# Application base path (e.g., / or /some-folder/)
NUXT_APP_BASE_URL=

# Build version shown in the UI footer (short git sha). Set automatically by Dockerfile.app at
# build time (CI passes the real commit); leave empty locally to fall back to "dev".
NUXT_PUBLIC_GIT_SHA=

# --- SECURITY ---
# Comma-separated list of allowed hosts for Vite dev server NUXT_ALLOWED_HOSTS="example.com,foo.com"
NUXT_ALLOWED_HOSTS=

# --- API KEYS ---
# Используется ТОЛЬКО dev-утилитой перевода i18n (tools/translate.ui.ts).
# В рантайме UI не обращается к AI напрямую (вся обработка — через backend); в проде НЕ нужен.
# DeepSeek API Key (Get it at: https://platform.deepseek.com)
DEEPSEEK_API_KEY=your_api_key_here
