# Note on local test runs: `vitest.config.ts` narrows `envPrefix` to
# `['VITE_', 'NUXT_BITRIX24_TEST_', 'DEEPSEEK_']`, so the only entries from
# this file the test suite actually autoloads are `NUXT_BITRIX24_TEST_*` for
# integration tests and `DEEPSEEK_*` for evals. Production-shaped names like
# `NUXT_BITRIX24_WEBHOOK_URL`, `NUXT_MCP_AUTH_TOKEN`, `NUXT_GITHUB_FEEDBACK_TOKEN`,
# `NUXT_LOG_LEVEL`, `NUXT_AUDIT_DIR` stay invisible to the unit suite even when
# you keep them here for `pnpm dev`. Shell exports (`export NUXT_…=`) still
# reach `process.env` directly — `tests/unit/mcp-stdio/shims.test.ts` wipes
# its known names per-case to cover that path.

# Bitrix24 — incoming webhook. Create it under a dedicated SERVICE USER (admin
# rights only if you need cross-user visibility), not a personal account. See
# README "Quick start" for why.
#
# Cloud — any TLD (the SDK does not validate it):
#   https://your-portal.bitrix24.com/rest/<user_id>/<secret>/
#   https://your-portal.bitrix24.ru/rest/<user_id>/<secret>/      (RU)
#   https://your-portal.bitrix24.com.br/rest/<user_id>/<secret>/  (BR)
#   https://your-portal.bitrix24.es/rest/<user_id>/<secret>/      (ES/LatAm)
#   https://your-portal.bitrix24.de/rest/<user_id>/<secret>/      (DE)
#
# Self-Hosted (on-prem) — any domain, same URL shape, e.g.:
#   https://crm.company.local/rest/<user_id>/<secret>/
#
# For Self-Hosted on a private/self-signed CA also set NODE_EXTRA_CA_CERTS
# below — Node's default trust list won't include it.
NUXT_BITRIX24_WEBHOOK_URL=https://your-portal.bitrix24.com/rest/your-user-id/your-webhook-code/

# MCP server — Bearer token Claude (or other client) must present
#
# Generation:
#   Linux / macOS / WSL / Git-Bash:  openssl rand -hex 32
#   PowerShell (Windows 10+):        -join ((48..57)+(97..102) | Get-Random -Count 64 | %{[char]$_})
#   Any platform with Node:          node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Any random string of 32+ characters is fine — the value is compared via
# `crypto.timingSafeEqual`, length-leak is acceptable for fixed-length tokens.
# IMPORTANT: leaving the literal `replace-with-secure-token` placeholder makes
# /mcp return 503 (treated as "not configured") — replace it before starting.
NUXT_MCP_AUTH_TOKEN=replace-with-secure-token

# GitHub feedback — token used by bx24mcp_submit_feedback
# Use a fine-grained Personal Access Token (github.com → Settings → Developer
# settings → Personal access tokens → Fine-grained tokens) scoped to:
#   - Repository access: only bitrix24/templates-mcp
#   - Repository permissions → Issues: Read and write
NUXT_GITHUB_FEEDBACK_TOKEN=github_pat_xxx
NUXT_GITHUB_FEEDBACK_REPO=bitrix24/templates-mcp

# Eval LLM (optional, only for tests/evals).
# DEEPSEEK_BASE_URL accepts any OpenAI-compatible chat-completions endpoint —
# point it at a local Ollama, GigaChat, Yandex GPT proxy, etc. The env var name
# stays DEEPSEEK_* because that is what the eval suite expects, but the
# underlying SDK is provider-agnostic.
DEEPSEEK_API_KEY=sk-xxx
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Integration tests (optional).
# IMPORTANT: point this at an isolated/staging portal, never production —
# the live suite calls real REST methods against whatever portal you supply.
# Example: NUXT_BITRIX24_TEST_WEBHOOK_URL=https://for-test.bitrix24.com/rest/test-user-id/test-webhook-code/
NUXT_BITRIX24_TEST_WEBHOOK_URL=

# Application
#
# NODE_ENV — two different files, two different rules:
#   This file (repo root .env) — do NOT add NODE_ENV=production.
#     Nuxt reads this file during `pnpm dev` / `pnpm test` and breaks
#     when it sees NODE_ENV=production.
#   Server .env (next to docker-compose.yml on the host) — DO add it:
#     echo "NODE_ENV=production" >> .env
#     Docker Compose reads it only for variable substitution; Nuxt never
#     sees it there, so the restriction does not apply.
#
# Uncomment the line below only in the HOST .env, never in this repo file:
# NODE_ENV=production
NUXT_LOG_LEVEL=info
NITRO_PORT=3000

# Self-hosted Bitrix24 with a private/self-signed CA: pin the trust bundle.
# Leave empty for cloud portals — Node ships Mozilla's CA list by default.
# NODE_EXTRA_CA_CERTS=/etc/ssl/certs/bitrix-internal-ca.pem

# OAuth/Bearer audit-log directory. Read by server/utils/audit-log.ts.
# Default `/data/audit/`. Must be an ABSOLUTE path with no `..` segments;
# the server creates it `0750` and writes JSONL files `0640`. Operators
# MUST configure rotation/retention (logrotate or find -mtime) — see
# docs/DEPLOYMENT.md "Monitoring & logs" and docs/SECURITY-AUDIT.md.
# A webhook-only deploy NEVER writes here — leave commented until OAuth
# is enabled (`NUXT_BITRIX24_OAUTH_ENABLED=true`).
# NUXT_AUDIT_DIR=/data/audit

# Bitrix24 OAuth 2.0 / multi-tenant (opt-in). The full surface is LANDED
# and end-to-end live behind this flag — see `docs/OAUTH-DESIGN.md` and the
# "OAuth 2.0 multi-tenant" section of `docs/DEPLOYMENT.md`. With `=true`,
# each end user authorises via `/api/oauth/install` and every REST call runs
# under THAT user's Bitrix24 identity (no shared service user). With `=false`
# (the default) tools transparently keep using the webhook singleton — a
# webhook-only fork sees zero behaviour change.
#
# ⚠ MIGRATION — READ BEFORE FLIPPING THE FLAG. When NUXT_BITRIX24_OAUTH_ENABLED
# =true, NUXT_MCP_AUTH_TOKEN is BYPASSED on /mcp: the endpoint stops accepting
# the legacy shared token and accepts ONLY a per-user OAuth Bearer minted via
# /api/oauth/install → /api/oauth/callback. Every connected client (Claude /
# Cursor / Windsurf) must swap its `Authorization: Bearer <NUXT_MCP_AUTH_TOKEN>`
# header for its own per-user Bearer BEFORE you enable the flag, or it gets a
# 401 with `WWW-Authenticate: Bearer error="invalid_token", errorCode="…",
# error_description="…"`.
# Rollback is just `=false` + restart — the SQLite store stays on disk.
#
# Enable only after you have:
#   1. Registered a Bitrix24 Marketplace application (CLIENT_ID/SECRET below).
#   2. Persistent volume mounted at the directory holding `oauth.sqlite`
#      (docker-compose.yml already declares `bx24_data:/data`).
#   3. HTTPS callback URL reachable from Bitrix24 (matches REDIRECT_URL).
# `_DB_DIR` is the directory that holds `oauth.sqlite` (the filename is
# fixed in code, matches the `NUXT_AUDIT_DIR` shape). Must be a writable,
# persistent mount with an ABSOLUTE path (no `..` segments — the server
# validates this at boot and refuses to start otherwise). The
# docker-compose `bx24_data:/data` volume satisfies this by default. If
# you omit `_DB_DIR` AND don't mount a volume at `/data`, the DB lands in
# the container's ephemeral layer and is lost on restart — a silent
# data-loss trap: on the next restart every minted Bearer is gone and all
# users must re-run `/api/oauth/install`. Always mount a persistent volume.
#
# `_ADMIN_TOKEN` gates GET /api/oauth/_health (operator-tier counts
# endpoint). It is DELIBERATELY separate from NUXT_MCP_AUTH_TOKEN — the
# agent's token must never read fleet-level OAuth counts. Leave EMPTY to
# allow localhost-only access (the recommended pattern: an nginx
# `location /api/oauth/_health { allow <ops-cidr>; deny all; }` block).
# Set it to an `openssl rand -hex 32` value if you can't isolate the
# route at the network layer. The route fails closed: with neither set,
# a non-localhost request gets 503 NOT-CONFIGURED. Once `_ADMIN_TOKEN` is
# set the Bearer is required uniformly — even a localhost request needs it.
#
# SCALING CAVEAT: the OAuth token cache + refresh state are PROCESS-LOCAL
# (single-instance design, see docs/OAUTH-DESIGN.md §5). Running 2+
# replicas behind a load balancer means each refreshes tokens
# independently and `/api/oauth/_health` counts/timestamps differ per
# replica — a revoke on one replica isn't seen by another until its
# cache entry is evicted. Keep this to a single instance until a shared
# token store lands (§12 HA-store item).
# NUXT_BITRIX24_OAUTH_ENABLED=false
# NUXT_BITRIX24_OAUTH_CLIENT_ID=
# NUXT_BITRIX24_OAUTH_CLIENT_SECRET=
# NUXT_BITRIX24_OAUTH_REDIRECT_URL=https://prod.example.com/api/oauth/callback
# NUXT_BITRIX24_OAUTH_SCOPE=user,task
# NUXT_BITRIX24_OAUTH_DB_DIR=/data
# NUXT_BITRIX24_OAUTH_ADMIN_TOKEN=

# Docker Compose project name (#189). Isolates this stack from other compose
# projects on the same host. Without it Compose derives the project name from
# the directory (`templates-mcp`, `opt`, …), which varies per operator and
# collides when a second environment (e.g. staging) lands on the same machine:
# `docker compose up` in the staging directory would restart/overwrite the
# production containers. Set a distinct value per environment, e.g.
# `bx24-mcp-prod` and `bx24-mcp-staging`. The app stack (docker-compose.yml)
# reads this; the reverse-proxy stack (docker-compose.server.yml) is a host
# singleton with its own fixed name and ignores it.
#
# ⚠ UPGRADING from a pre-#189 stack with existing OAuth data (oauth.sqlite +
#   audit log in the `bx24_data` volume)? Read the BREAKING entry in
#   CHANGELOG.md (under v0.3.0 → Changed → "Compose project name…") and
#   docs/RUNBOOK.md § "Container naming after #189" BEFORE you run
#   `docker compose up` — the volume gets a new prefix and orphans silently
#   if you don't keep the old project name or migrate it deliberately.
COMPOSE_PROJECT_NAME=bx24-mcp

# nginx-proxy + acme-companion (production deployment only).
# If you terminate TLS via Caddy / Traefik / plain nginx+certbot instead, the
# four variables below are unused — see docs/REVERSE-PROXY.md for snippets.
VIRTUAL_HOST=prod.example.com
VIRTUAL_PORT=3000
LETSENCRYPT_HOST=prod.example.com
LETSENCRYPT_EMAIL=admin@example.com

