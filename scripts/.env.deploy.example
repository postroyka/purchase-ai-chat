# Настройки полуручного деплоя b24-controller (scripts/deploy-b24-controller.sh).
# Скопировать в scripts/.env.deploy и заполнить. Файл .env.deploy не коммитится.

B24_SSH_HOST=b24.postroyka.by
B24_SSH_USER=bitrix
B24_SSH_PORT=22
# Абсолютный путь до каталога контроллеров живого модуля shef.purchase:
B24_CONTROLLERS_PATH=/home/bitrix/www/bitrix/modules/shef.purchase/lib/controllers
