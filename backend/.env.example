# Backend local dev environment
# Скопировать: cp .env.example .env
# .env не коммитится (в .gitignore)

BACKEND_API_TOKEN=dev-token-local
NODE_ENV=development
PORT=3000
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=20
MAX_FILES_PER_REQUEST=10
ALLOWED_EXTENSIONS=pdf,xlsx,docx

# Redis — оставить пустым для in-memory (нормально для Week 1 локально)
# Или: redis://localhost:6379
REDIS_URL=
JOB_TTL_HOURS=24

# MCP. Локально обычно не нужен (инструменты — заглушки) — можно оставить пустым.
# Если запускаете MCP локально (в mcp/: PORT=3002 pnpm dev), укажите его адрес:
MCP_SERVER_URL=http://localhost:3002/mcp
