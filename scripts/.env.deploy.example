# Настройки полуручного деплоя b24-controller (scripts/deploy-b24-controller.sh)
# и smoke-теста (scripts/smoke-test-b24.sh / .ps1).
# Скопировать в scripts/.env.deploy и заполнить. Файл .env.deploy НЕ коммитится
# (в .gitignore) — поэтому здесь безопасно хранить вебхук с токеном.

# --- Деплой контроллеров (deploy-b24-controller.sh) ---
# Боевая коробка — b24.postroyka.by; тест/dev (staging) — tstb24.postroyka.by.
# Переключение staging↔prod = смена B24_SSH_HOST (и при необходимости WEBHOOK_URL ниже).
B24_SSH_HOST=b24.postroyka.by
B24_SSH_USER=bitrix
B24_SSH_PORT=22
# Пароль SSH (опц.; нужен пакет sshpass). Если не задан — используется SSH-ключ/agent.
# Можно с префиксом PAI_ (PAI_B24_SSH_PASS). Передаётся через SSHPASS, не в argv.
# B24_SSH_PASS=
# Абсолютный путь до каталога контроллеров живого модуля shef.purchase:
B24_CONTROLLERS_PATH=/home/bitrix/www/bitrix/modules/shef.purchase/lib/controllers

# --- Smoke-тест REST-контроллеров (smoke-test-b24.sh / smoke-test-b24.ps1) ---
# Оба скрипта автоматически подхватывают этот файл, если он существует, —
# тогда длинную команду с env-переменными набирать не нужно, достаточно:
#   bash scripts/smoke-test-b24.sh           (Linux)
#   ./scripts/smoke-test-b24.ps1             (Windows)
#
# ВАЖНО: значения с пробелами берите в кавычки (работает в обоих скриптах):
#   VENDOR_CODE="тех 100х25х6000"
#   CONTRACT_NUMBER="Договор 39/88-20"

# Входящий вебхук Bitrix24 с токеном (обязательно; при APPLY=1 деплой требует его
# для пост-деплой health-чека). Можно назвать WEBHOOK_URL или PAI_WEBHOOK_URL.
# ⚠️ Вебхук должен указывать на ТУ ЖЕ коробку, что и B24_SSH_HOST — при переключении
# staging↔prod меняйте оба. Тест/dev:
WEBHOOK_URL=https://tstb24.postroyka.by/rest/13/replace-with-webhook-token/
# Прод (раскомментируйте при деплое на боевую b24, закомментировав строку выше):
# WEBHOOK_URL=https://b24.postroyka.by/rest/13/replace-with-webhook-token/

# Реальный 9-значный УНП поставщика из коробки (кейс 1a):
SUPPLIER_UNP=100059180
# ID компании-поставщика в CRM — число из URL карточки компании (кейсы 2a, 4a):
SUPPLIER_ID=42
# Артикул товара из каталога, поле PURCHASE_ARTICLE (кейс 3a).
# Значения с пробелами — в кавычках, напр.: VENDOR_CODE="тех 100х25х6000"
VENDOR_CODE=ART-12345
# ID ответственного пользователя (b_user) для создаваемой сделки (кейс 4a):
RESPONSIBLE_USER_ID=1
# Реальные номер и дата существующего у SUPPLIER_ID договора (из вывода 2a) —
# для проверки фильтра по номеру/дате (кейсы 2b–2d). Пусто → 2b–2d пропускаются.
CONTRACT_NUMBER="Договор 39/88-20"
CONTRACT_DATE=17.04.2020
