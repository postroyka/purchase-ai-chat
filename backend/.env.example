# Backend local dev environment
# Скопировать: cp .env.example .env
# .env не коммитится (в .gitignore)

BACKEND_API_TOKEN=dev-token-local
NODE_ENV=development
PORT=3000
UPLOAD_DIR=uploads
# Авто-чистка uploads/: удалять папки job'ов старше N суток (нижняя граница — 1). По умолчанию 7.
UPLOADS_RETENTION_DAYS=7
MAX_FILE_SIZE_MB=20
MAX_FILES_PER_REQUEST=10
ALLOWED_EXTENSIONS=pdf,xlsx,docx,xls,jpg,jpeg,png
# OCR_LANGS=rus+eng+bel   # языки OCR (нужен tesseract на хосте); OCR_DPI=150, MAX_OCR_PAGES=8 — тюнинг

# Детальные замеры на странице результата (#замеры): при true /job/:id/status отдаёт по файлам тайминги
# (startedAt/agentMs/agentTurns/durationMs/extractMethod/extractMs) + флаг showTimings; UI показывает
# «⏱ всего … · агент … (N ходов, #222) · извлечение: ocr 2.3 с» (#203.2) по готовности. Только в лог.
# По умолчанию выключено (opt-in). Живой mm:ss «обрабатывается N сек» показывается ВСЕГДА (#203).
SHOW_TIMINGS=false
# Пороги «быстро/медленно» по полному времени файла для лога замеров (оценочные — калибруйте реальностью,
# см. docs/PARSING_PERFORMANCE.md). durationMs ≤ FAST → быстро, ≥ SLOW → медленно, между — норма.
TIMING_FAST_MS=45000
TIMING_SLOW_MS=90000

# Redis — оставить пустым для in-memory (нормально для Week 1 локально)
# Или: redis://localhost:6379
REDIS_URL=
JOB_TTL_HOURS=24

# Claude Code Agent (backend/agent-runner.js → runAgent)
CLAUDE_CODE_BIN=claude
AGENT_TIMEOUT_MS=360000           # лимит ОДНОЙ попытки claude в мс (6 мин, #260)
AGENT_FILE_BUDGET_MS=720000       # общий бюджет на ФАЙЛ: extract/OCR + все попытки (12 мин, #285)
# Ретрай на транзиентные сбои провайдера (429/5xx/сеть) с бэкоффом+джиттером (#104). Перманентные
# ошибки И наши таймауты (попытка #260, бюджет файла #285) НЕ ретраятся. 1 = выкл.
AGENT_MAX_ATTEMPTS=3              # всего попыток (вкл. первую)
AGENT_RETRY_BASE_MS=1000         # базовая задержка бэкоффа, мс
AGENT_RETRY_MAX_MS=15000         # потолок задержки между попытками, мс
# Allowlist инструментов агента (#105 P2): по умолч. Read + наши MCP-инструменты b24_pst_crm_*
# (сервер mcp__procure-ai__). Менять только если в окружении другое имя MCP-сервера/набор. Синтаксис:
# Read,mcp__<server>__<tool>,…  (новые встроенные инструменты будущих версий CLI агенту НЕ доступны).
# AGENT_ALLOWED_TOOLS=Read,mcp__procure-ai__b24_pst_crm_find_supplier,mcp__procure-ai__b24_pst_crm_create_deal
# CLAUDE_MODEL=claude-sonnet-4-6  # опционально: модель агента (по умолч. — из настроек claude CLI)
# ANTHROPIC_API_KEY=sk-ant-...    # нужен ТОЛЬКО если не залогинен интерактивно (claude login).
                                  # В Docker подписочная сессия не работает — ключ обязателен.
# Диагностика канала «Обратная связь агента»: при true агент-раннер на КАЖДОМ файле добавляет один
# тестовый feedback, если агент сам не прислал → metrics.recordFeedback (панель /metrics) + GitHub
# issue (если задан GITHUB_FEEDBACK_TOKEN). Способ проверить канал, пока агент сам молчит. По умолч. off.
# Точечно, без рестарта: POST /upload?forceFeedback=1 форсит только на ОДИН аплоад (#205).
AGENT_FORCE_FEEDBACK=false
# DeepSeek вместо Anthropic: вместо ANTHROPIC_API_KEY задать
# ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic + ANTHROPIC_AUTH_TOKEN + ANTHROPIC_MODEL.

# Чат-бот Битрикс24 (docs/B24_BOT.md): ФОЛБЭК application_token для валидации входящих событий бота
# на POST /b24/bot/event. Обычно токен ЗАХВАТЫВАЕТСЯ автоматически при установке через
# POST /b24/app/event (#217) и хранится в Redis — тогда env не нужен. Задать, только если callback
# установки не настроен (одно-портальная установка). Пусто И нет захваченного → 403.
B24_BOT_APPLICATION_TOKEN=

# MCP — для локального e2e подними mcp отдельно. Backend уже занимает :3000, поэтому
# запускай MCP на ДРУГОМ порту и укажи его здесь. Оставь пустым, если агент не нужен.
MCP_SERVER_URL=http://localhost:3002/mcp
NUXT_MCP_AUTH_TOKEN=
