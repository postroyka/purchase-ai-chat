# Note on local test runs: `vitest.config.ts` narrows `envPrefix` to
# `['VITE_', 'NUXT_BITRIX24_TEST_', 'DEEPSEEK_']`, so the only entries from
# this file the test suite actually autoloads are `NUXT_BITRIX24_TEST_*` for
# integration tests and `DEEPSEEK_*` for evals. Production-shaped names like
# `NUXT_BITRIX24_WEBHOOK_URL`, `NUXT_MCP_AUTH_TOKEN`, `NUXT_GITHUB_FEEDBACK_TOKEN`,
# `NUXT_LOG_LEVEL`, `NUXT_AUDIT_DIR` stay invisible to the unit suite even when
# you keep them here for `pnpm dev`. Shell exports (`export NUXT_…=`) still
# reach `process.env` directly — `tests/unit/mcp-stdio/shims.test.ts` wipes
# its known names per-case to cover that path.

# Bitrix24 — incoming webhook. Create it under a dedicated SERVICE USER (admin
# rights only if you need cross-user visibility), not a personal account. See
# README "Quick start" for why.
#
# Cloud — any TLD (the SDK does not validate it):
#   https://your-portal.bitrix24.com/rest/<user_id>/<secret>/
#   https://your-portal.bitrix24.ru/rest/<user_id>/<secret>/      (RU)
#   https://your-portal.bitrix24.com.br/rest/<user_id>/<secret>/  (BR)
#   https://your-portal.bitrix24.es/rest/<user_id>/<secret>/      (ES/LatAm)
#   https://your-portal.bitrix24.de/rest/<user_id>/<secret>/      (DE)
#
# Self-Hosted (on-prem) — any domain, same URL shape, e.g.:
#   https://crm.company.local/rest/<user_id>/<secret>/
#
# For Self-Hosted on a private/self-signed CA also set NODE_EXTRA_CA_CERTS
# below — Node's default trust list won't include it.
NUXT_BITRIX24_WEBHOOK_URL=https://your-portal.bitrix24.com/rest/your-user-id/your-webhook-code/

# MCP server — Bearer token Claude (or other client) must present
#
# Generation:
#   Linux / macOS / WSL / Git-Bash:  openssl rand -hex 32
#   PowerShell (Windows 10+):        -join ((48..57)+(97..102) | Get-Random -Count 64 | %{[char]$_})
#   Any platform with Node:          node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Any random string of 32+ characters is fine — the value is compared via
# `crypto.timingSafeEqual`, length-leak is acceptable for fixed-length tokens.
# IMPORTANT: leaving the literal `replace-with-secure-token` placeholder makes
# /mcp return 503 (treated as "not configured") — replace it before starting.
NUXT_MCP_AUTH_TOKEN=replace-with-secure-token

# GitHub feedback — token used by bx24mcp_submit_feedback
# Use a fine-grained Personal Access Token (github.com → Settings → Developer
# settings → Personal access tokens → Fine-grained tokens) scoped to:
#   - Repository access: only bitrix24/templates-mcp
#   - Repository permissions → Issues: Read and write
NUXT_GITHUB_FEEDBACK_TOKEN=github_pat_xxx
NUXT_GITHUB_FEEDBACK_REPO=bitrix24/templates-mcp

# Eval LLM (optional, only for tests/evals).
# DEEPSEEK_BASE_URL accepts any OpenAI-compatible chat-completions endpoint —
# point it at a local Ollama, GigaChat, Yandex GPT proxy, etc. The env var name
# stays DEEPSEEK_* because that is what the eval suite expects, but the
# underlying SDK is provider-agnostic.
DEEPSEEK_API_KEY=sk-xxx
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Integration tests (optional).
# IMPORTANT: point this at an isolated/staging portal, never production —
# the live suite calls real REST methods against whatever portal you supply.
# Example: NUXT_BITRIX24_TEST_WEBHOOK_URL=https://for-test.bitrix24.com/rest/test-user-id/test-webhook-code/
NUXT_BITRIX24_TEST_WEBHOOK_URL=

# Application
#
# NODE_ENV — two different files, two different rules:
#   This file (repo root .env) — do NOT add NODE_ENV=production.
#     Nuxt reads this file during `pnpm dev` / `pnpm test` and breaks
#     when it sees NODE_ENV=production.
#   Server .env (next to docker-compose.yml on the host) — DO add it:
#     echo "NODE_ENV=production" >> .env
#     Docker Compose reads it only for variable substitution; Nuxt never
#     sees it there, so the restriction does not apply.
#
# Uncomment the line below only in the HOST .env, never in this repo file:
# NODE_ENV=production
NUXT_LOG_LEVEL=info
NITRO_PORT=3000

# Self-hosted Bitrix24 with a private/self-signed CA: pin the trust bundle.
# Leave empty for cloud portals — Node ships Mozilla's CA list by default.
# NODE_EXTRA_CA_CERTS=/etc/ssl/certs/bitrix-internal-ca.pem

# OAuth/Bearer audit-log directory. Read by server/utils/audit-log.ts.
# Default `/data/audit/`. Must be an ABSOLUTE path with no `..` segments;
# the server creates it `0750` and writes JSONL files `0640`. Operators
# MUST configure rotation/retention (logrotate or find -mtime) — see
# docs/DEPLOYMENT.md "Monitoring & logs" and docs/SECURITY-AUDIT.md.
# A webhook-only (Phase-1) deploy NEVER writes here — leave commented
# until the OAuth flow (Phase-3) is in scope.
# NUXT_AUDIT_DIR=/data/audit

# nginx-proxy + acme-companion (production deployment only).
# If you terminate TLS via Caddy / Traefik / plain nginx+certbot instead, the
# four variables below are unused — see docs/REVERSE-PROXY.md for snippets.
VIRTUAL_HOST=prod.example.com
VIRTUAL_PORT=3000
LETSENCRYPT_HOST=prod.example.com
LETSENCRYPT_EMAIL=admin@example.com

