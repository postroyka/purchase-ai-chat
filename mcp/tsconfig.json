// Project-references shape per Nuxt 4 convention. Each sub-tsconfig is
// generated by `nuxt prepare` and covers its own runtime context (app / Nitro
// server / node config / shared types). Tests live under tests/ and are
// type-checked by Vitest's own transform; including them in a project
// reference here would strip Nitro auto-imports via `extends` semantics.
{
  "files": [],
  "references": [
    { "path": "./.nuxt/tsconfig.app.json" },
    { "path": "./.nuxt/tsconfig.server.json" },
    { "path": "./.nuxt/tsconfig.shared.json" },
    { "path": "./.nuxt/tsconfig.node.json" }
  ]
}
